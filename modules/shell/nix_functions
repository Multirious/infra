# Usage: nix-try <nixpkgs name> <command>
nix-try () {
  package="$1"
  shift
  nix shell "nixpkgs#$package" --command $*
}

# Usage: nix-view <nixpkgs name>
nix-view () {
  cd $(nix-build '<nixpkgs>' --attr "$1" --no-out-link)
}

nix-shell-temp () {
  temp_dir="$(mktemp -d)"
  nix-shell "$@" --command "cd $temp_dir; return"
  rm -rf "$temp_dir"
}
